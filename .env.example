# =============================================================================
# Agent Trading System — Local Development Environment Template
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---- Application -----------------------------------------------------------
APP_ENV=live
APP_TIMEZONE=Asia/Seoul

# ---- Scheduler -------------------------------------------------------------
# 일반 BUY lane 하루 제출 상한.
# ops-scheduler는 이 값을 읽어 `--max-general-buy-submit-per-day`로 전달한다.
# 설정하지 않으면 docker-compose 기본값 6을 사용.
SCHEDULER_MAX_GENERAL_BUY_SUBMIT_PER_DAY=8
#
# 참고:
# - `MAX_GENERAL_BUY_SUBMIT_PER_DAY` 는 현재 읽지 않는다.
# - `--max-submit-per-day` 는 deprecated alias 이며, 새 기준 이름은
#   `--max-general-buy-submit-per-day` / `SCHEDULER_MAX_GENERAL_BUY_SUBMIT_PER_DAY` 이다.

# ---- Korea Investment & Securities (KIS) ----------------------------------
# Preferred naming (한국투자증권 actual standard):
KIS_ENV=paper           # "paper" | "real" (normalized to "live" internally)
KIS_APP_KEY=""
KIS_APP_SECRET=""
KIS_ACCOUNT_NO=""
KIS_ACCOUNT_PRODUCT_CODE=01
#
# REST rate limit safety budget baseline (env override):
# KIS official notice 2026-04-20: 실전 REST 계좌당 초당 18건, 모의 초당 1건
KIS_REAL_REST_RPS=      # live/real environment aggregate RPS
KIS_PAPER_REST_RPS=     # paper environment aggregate RPS (1 for api + 2 for snapshot-sync)
#
# Dev token cache (paper/dev only — live/real에서는 무시됨):
# 파일 기반 access token 캐시로 프로세스 간 토큰 재사용.
# Roo Code가 테스트/스크립트를 별도 프로세스로 실행할 때
#
KIS_DEV_TOKEN_CACHE_ENABLED=true
KIS_DEV_TOKEN_CACHE_PATH=.cache/kis_token.json
#
# Live market-info/read-only client — authoritative live credential.
# 운영정보(국내휴장일조회, ops-scheduler 076 REST session gate)와 Admin UI
# "실시간 현재가" 화면(KIS WebSocket 시세 수신 + REST fallback, `api` 프로세스)이
# 함께 쓰는 **단일 authoritative live appkey**다. 주문/잔고/체결/submit 경로에는
# 사용하지 말고, read-only 시장 운영 정보/시세 조회에만 사용.
# 비워두면 076 세션 게이트는 fallback 정책을 쓰고, 실시간 현재가 화면은
# mock(in-memory) source로 동작한다 — 주문/체결 경로에는 영향 없음.
#
# 2026-07-10: ops-scheduler는 163 WebSocket(장운영정보 실시간 phase, KisMarketStateClient)
# 의존을 제거했다 — session source는 076 REST(KisHolidayProvider, 아래 ENABLED/APP_KEY/
# APP_SECRET/BASE_URL 사용) + FallbackSessionProvider(시계 기반)로 고정된다.
# 이 appkey의 WS 세션은 이제 `api` 프로세스(실시간 현재가 화면)만 소유한다
# (§4.2 WebSocket Session 1개 원칙 유지) — ops-scheduler는 WS를 전혀 열지 않는다.
# 근거: plans/[PRIORITY_MAP] remaining_work_priority_map.md 항목 20.
#
# 2026-07-10: 실시간 현재가 화면의 credential도 기존 KIS_REALTIME_QUOTE_*(별도
# 전용 appkey)에서 이 KIS_LIVE_INFO_*로 통합했다 — KIS_REALTIME_QUOTE_*는
# deprecated이며, 아래에 짧은 하위 호환 fallback으로만 남아 있다(신규 배포는
# 설정할 필요 없음).
KIS_LIVE_INFO_ENABLED=true
KIS_LIVE_INFO_APP_KEY=""
KIS_LIVE_INFO_APP_SECRET=""
KIS_LIVE_INFO_BASE_URL="https://openapi.koreainvestment.com:9443"
KIS_LIVE_INFO_WS_URL="ws://ops.koreainvestment.com:21000"
#
# WS approval-key 캐시 전용(현재 163 WS 제거로 사실상 미사용) — 076 holiday
# client의 REST access token은 더 이상 이 경로를 쓰지 않는다(아래
# KIS_DISCLOSURE_TOKEN_CACHE_* 참고).
KIS_LIVE_TOKEN_CACHE_ENABLED=true
KIS_LIVE_TOKEN_CACHE_PATH=.cache/kis_live_token.json
# 실시간 현재가 화면 전용 WebSocket approval-key 파일 캐시(트레이딩/공시 계좌
# 캐시와 분리된 별도 파일).
KIS_LIVE_INFO_APPROVAL_CACHE_PATH=.cache/kis_live_info_approval_key.json
#
# [2026-07-13 토큰 캐시 통합] 076(휴장일 조회) client와 공시/시세 client는
# 같은 KIS_LIVE_INFO_* appkey로 인증하는 동일한 REST access token
# (oauth2/tokenP)을 쓰므로, 아래 KIS_DISCLOSURE_TOKEN_CACHE_* 캐시 파일을
# **공유**한다(더 이상 KIS_LIVE_TOKEN_CACHE_PATH를 쓰지 않음) — cold start 시
# 같은 appkey로 토큰이 중복 발급되어 KIS 1분당 1회 제한(EGW00133)에 걸리는
# 것을 방지하기 위함. 상세: plans/[BACKLOG] backlog.md
# "KIS 토큰 캐시 통합(appkey당 1개)".
KIS_DISCLOSURE_TOKEN_CACHE_ENABLED=true
KIS_DISCLOSURE_TOKEN_CACHE_PATH=.cache/kis_disclosure_token.json
#
# [Deprecated, 2026-07-10] Realtime-quote screen legacy credential.
# 더 이상 표준 설정이 아니다 — 위 KIS_LIVE_INFO_*가 비어 있을 때만
# `build_realtime_quote_source()`의 하위 호환 fallback으로 참조된다.
# 신규 배포에서는 설정하지 말 것.
# KIS_REALTIME_QUOTE_APP_KEY=""
# KIS_REALTIME_QUOTE_APP_SECRET=""
# KIS_REALTIME_QUOTE_BASE_URL="https://openapi.koreainvestment.com:9443"
# KIS_REALTIME_QUOTE_WS_URL="ws://ops.koreainvestment.com:21000"
# KIS_REALTIME_QUOTE_APPROVAL_CACHE_PATH=.cache/kis_realtime_quote_approval_key.json
#
# Trading REST approval key file cache (optional, conservative default off):
# - REST client의 `get_approval_key()` 결과를 프로세스 재시작 간 재사용한다.
# - live-info websocket approval key cache(`KIS_LIVE_TOKEN_CACHE_PATH`)와는 별도 파일을 쓴다.
KIS_APPROVAL_KEY_CACHE_ENABLED=false
KIS_APPROVAL_KEY_CACHE_PATH=.cache/kis_rest_approval_key.json

# ---- PostgreSQL (primary DATABASE_* prefix) --------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=trading
DATABASE_USER=trading
DATABASE_PASSWORD=
DATABASE_SCHEMA=trading

# ---- PostgreSQL (backward-compatible DB_* fallback) ------------------------
# These are supported but DATABASE_* takes precedence when both are set.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=trading
# DB_USER=trading
# DB_PASSWORD=trading

# ---- Provider AI (DeepSeek / OpenAI-compatible / Gemini) -----------------------------
# LLM_PROVIDER controls which set of env vars is read.
# Supported values: deepseek (default), openai, gemini
LLM_PROVIDER=gemini
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120

# --- Gemini Configuration Example ---
# To use Gemini API (Recommended: gemini-2.5-flash for best speed/accuracy balance)
# LLM_PROVIDER=gemini
GEMINI_API_KEY="your_gemini_api_key_here"
# To use the OpenAI-compatible endpoint with Gemini:
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL_ID="gemini-2.5-flash"
GEMINI_TIMEOUT_SECONDS=120

# --- OpenAI Configuration Example ---
# To switch to OpenAI, set LLM_PROVIDER=openai and uncomment:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL_ID="gpt-4o"
# OPENAI_TIMEOUT_SECONDS=30

# ---- OpenDART Open API Key  -------------------------------------------------
OPENDART_API_KEY=""

# ---- Naver News Search API Key  ---------------------------------------------
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ---- FastAPI inspection/admin API Token  ------------------------------------
INSPECTION_API_TOKEN=dev-token-123

# =============================================================================
# Agent Trading System — Local Development Environment Template
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---- Application -----------------------------------------------------------
APP_ENV=paper
APP_TIMEZONE=Asia/Seoul

# ---- Korea Investment & Securities (KIS) ----------------------------------
# Preferred naming (한국투자증권 actual standard):
KIS_ENV=paper
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_BASE_URL="https://openapivts.koreainvestment.com:29443"
KIS_WS_URL="ws://ops.koreainvestment.com:31000"

KIS_ACCOUNT_PRODUCT_CODE=01

# 한국투자증권 실전매매를 위한 KEY 설정:
#KIS_ENV=real	
#KIS_APP_KEY=
#KIS_APP_SECRET=
#KIS_ACCOUNT_NO=
#KIS_BASE_URL="https://openapivts.koreainvestment.com:9443"
#KIS_WS_URL="ws://ops.koreainvestment.com:21000"
#
# REST rate limit safety budget baseline (env override):
# KIS official notice 2026-04-20: 실전 REST 계좌당 초당 18건, 모의 초당 1건
KIS_REAL_REST_RPS=18     # live/real environment aggregate RPS
KIS_PAPER_REST_RPS=1     # paper environment aggregate RPS
#
# Dev token cache (paper/dev only — live/real에서는 무시됨):
# 파일 기반 access token 캐시로 프로세스 간 토큰 재사용.
# Roo Code가 테스트/스크립트를 별도 프로세스로 실행할 때
# oauth2/tokenP 재발급 남용을 방지한다.
KIS_DEV_TOKEN_CACHE_ENABLED=true
KIS_DEV_TOKEN_CACHE_PATH=.cache/kis_token.json
#
# ---- KIS Snapshot Sync Scheduler -------------------------------------------
# Interval between auto-discover sync cycles (seconds). Default: 300 (5 min).
# Set shorter (e.g. 60) for development/testing, longer for production.
KIS_SNAPSHOT_SYNC_INTERVAL_SECONDS=300
#

# ---- PostgreSQL (primary DATABASE_* prefix) --------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SCHEMA=

# ---- PostgreSQL (backward-compatible DB_* fallback) ------------------------
# These are supported but DATABASE_* takes precedence when both are set.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# ---- Provider AI (DeepSeek / OpenAI-compatible) -----------------------------
# LLM_PROVIDER controls which set of env vars is read.
# Supported values: deepseek (default), openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=30
# GEMINI_API_KEY=
# To switch to OpenAI, set LLM_PROVIDER=openai and uncomment:
# OPENAI_API_KEY=
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL_ID="gpt-4o"
# OPENAI_TIMEOUT_SECONDS=30

# ---- FastAPI inspection/admin API Token  ------------------------------------
INSPECTION_API_TOKEN=
